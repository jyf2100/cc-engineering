#!/bin/bash
#
# Pre-commit hook: 敏感信息脱敏检查
# 检查暂存文件中是否包含 API Key、密码等敏感信息
#
# 安装方法:
#   cp scripts/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
# 或:
#   git config core.hooksPath scripts
#

set -e

# 颜色定义
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m' # No Color

echo -e "${GREEN}[Pre-commit] 开始敏感信息检查...${NC}"

# 获取暂存的文件（排除删除的文件）
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)

if [ -z "$STAGED_FILES" ]; then
    echo -e "${GREEN}[Pre-commit] 没有暂存的文件需要检查${NC}"
    exit 0
fi

# 敏感信息模式
PATTERNS=(
    # Anthropic API Keys
    'sk-ant-api03-[A-Za-z0-9_-]{95}'
    'sk-ant-[A-Za-z0-9_-]{20,}'

    # OpenAI API Keys
    'sk-[A-Za-z0-9]{20,}T3BlbkFJ[A-Za-z0-9]{20,}'
    'sk-proj-[A-Za-z0-9]{20,}'

    # Generic API Keys
    'api[_-]?key[_-]?=[_s]*['"'"'"][A-Za-z0-9_-]{20,}['"'"'"]'
    'apikey[_-]?=[_s]*['"'"'"][A-Za-z0-9_-]{20,}['"'"'"]'

    # AWS Keys
    'AKIA[0-9A-Z]{16}'
    'aws[_-]?secret[_-]?access[_-]?key[_-]?=[_s]*['"'"'"][A-Za-z0-9/+=]{40}['"'"'"]'

    # Private Keys
    '-----BEGIN (RSA |EC |DSA |OPENSSH )?PRIVATE KEY-----'
    '-----BEGIN PGP PRIVATE KEY BLOCK-----'

    # Password patterns
    'password[_-]?=[_s]*['"'"'"][^'"'"'}]{8,}['"'"'"]'
    'passwd[_-]?=[_s]*['"'"'"][^'"'"'}]{8,}['"'"'"]'

    # Database URLs
    'mysql://[^:]+:[^@]+@[^/]+'
    'postgresql://[^:]+:[^@]+@[^/]+'
    'mongodb(\+srv)?://[^:]+:[^@]+@[^/]+'
    'redis://[^:]*:[^@]+@[^/]+'

    # JWT Secrets
    'jwt[_-]?secret[_-]?=[_s]*['"'"'"][A-Za-z0-9_-]{20,}['"'"'"]'

    # GitHub Tokens
    'ghp_[A-Za-z0-9]{36}'
    'github[_-]?token[_-]?=[_s]*['"'"'"][A-Za-z0-9_-]{20,}['"'"'"]'

    # Generic Secrets
    'secret[_-]?key[_-]?=[_s]*['"'"'"][A-Za-z0-9_-]{20,}['"'"'"]'
)

# 白名单文件模式（这些文件不检查）
IGNORE_PATTERNS=(
    '\.gitignore$'
    '\.md$'
    '\.lock$'
    'package-lock\.json$'
    'yarn\.lock$'
    'pnpm-lock\.yaml$'
    '\.png$'
    '\.jpg$'
    '\.jpeg$'
    '\.gif$'
    '\.svg$'
    'pre-commit$'
)

FOUND_ISSUES=0

for FILE in $STAGED_FILES; do
    # 检查是否在白名单中
    SKIP=0
    for IGNORE in "${IGNORE_PATTERNS[@]}"; do
        if echo "$FILE" | grep -qE "$IGNORE"; then
            SKIP=1
            break
        fi
    done

    if [ $SKIP -eq 1 ]; then
        continue
    fi

    # 获取文件内容（从暂存区）
    CONTENT=$(git show ":$FILE" 2>/dev/null || true)

    if [ -z "$CONTENT" ]; then
        continue
    fi

    # 检查每个敏感模式
    for PATTERN in "${PATTERNS[@]}"; do
        if echo "$CONTENT" | grep -qiE -- "$PATTERN"; then
            # 获取匹配行号
            LINE_NUM=$(echo "$CONTENT" | grep -inE -- "$PATTERN" | head -1 | cut -d: -f1)
            MATCH=$(echo "$CONTENT" | grep -iE -- "$PATTERN" | head -1)

            echo -e "${RED}[ERROR] 发现敏感信息!${NC}"
            echo -e "  文件: ${YELLOW}$FILE${NC}"
            echo -e "  行号: $LINE_NUM"
            echo -e "  匹配: ${MATCH:0:80}..."
            echo ""
            FOUND_ISSUES=1
        fi
    done
done

if [ $FOUND_ISSUES -eq 1 ]; then
    echo -e "${RED}[Pre-commit] 检查失败！发现敏感信息。${NC}"
    echo -e "${YELLOW}请移除敏感信息或使用环境变量代替。${NC}"
    echo -e "${YELLOW}如需跳过检查（不推荐），使用: git commit --no-verify${NC}"
    exit 1
fi

echo -e "${GREEN}[Pre-commit] 检查通过，未发现敏感信息。${NC}"
exit 0
